# AI Image Generation Configuration
# Replace with your actual AI API provider URL (e.g., Replicate, OpenAI DALL-E, etc.)
NEXT_PUBLIC_AI_API_URL=https://api.provider.com/v1
AI_API_KEY=your_api_key_here

# MyFatoorah Payment Gateway Configuration
# Get these from your MyFatoorah account
MYFATOORAH_API_KEY=your_mf_api_key_here
MYFATOORAH_SECRET_KEY=your_mf_secret_key_here
NEXT_PUBLIC_MYFATOORAH_MODE=test

# Application Configuration
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_MAX_FREE_ATTEMPTS=2

# Resend Email Configuration
# Get your API key from https://resend.com/api-keys
RESEND_API_KEY=your_resend_api_key_here
RESEND_FROM_EMAIL=noreply@barq-studio.com
ADMIN_EMAIL=admin@barq-studio.com

# Optional: MyFatoorah Customer Identifier
MYFATOORAH_CUSTOMER_IDENTIFIER=
